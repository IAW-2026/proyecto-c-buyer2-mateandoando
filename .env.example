# ── Clerk ────────────────────────────────────────────────────────────────────
# https://clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=YOUR_DATABASE_POOLING_URL
DIRECT_URL=YOUR_DATABASE_DIRECT_URL

# ── Mocks toggle ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_USE_MOCKS=true/false

# ── Inter-app tokens ─────────────────────────────────────────────────────────
# Shared secret with Seller App  (X-Service-Token header)
X_SERVICE_TOKEN_SELLER=

# Shared secret with Payments App  (X-Api-Key header)
BUYER_APP_SECRET_KEY=YOUR_BUYER_APP_SECRET_KEY

# Shared API key sent to Shipping App  (X-Api-Key header)
BUYER_API_KEY=YOUR_BUYER_API_KEY

# ── External service URLs ─────────────────────────────────────────────────────
SELLER_API_URL=<https://>
PAYMENTS_API_URL=<https://>
SHIPPING_API_URL=<https://>
